# ==========================================
# 環境変数の設定テンプレート
# ==========================================
# このファイルをコピーして .env を作成し、各値を設定してください。
# cp .env.example .env

# LINE Messaging API
# LINE Developers Console から取得した値を設定してください
LINE_CHANNEL_ACCESS_TOKEN=ここにチャネルアクセストークンを貼る
LINE_USER_ID=ここにユーザーIDを貼る

# Google AI (Gemini)
GEMINI_API_KEY=ここにGemini APIキーを貼る

# Discord Webhook
DISCORD_WEBHOOK_URL=ここにDiscord Webhook URLを貼る

# Google Calendar (iCal形式の非公開URL)
# Google Calendar > 設定 > カレンダーの統合 > iCal形式の非公開URL
GOOGLE_CALENDAR_ICAL_URL=ここにGoogle Calendar iCal秘密URLを貼る
